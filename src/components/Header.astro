---
import { nav, links, site } from "../config/site";
// Inlined so the wordmark can use currentColor and adapt to the theme
// (light on dark, dark on light); the greens stay fixed.
import logoHorizontal from "../assets/timedart-logo-horizontal.svg?raw";

// Active nav item (primary tint). Homepage anchors can't be resolved to a
// section server-side, so only the section-level items (Docs) light up.
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href.startsWith("/docs") && path.startsWith("/docs");
---

<header class="site-header">
    <div class="wrap nav">
        <a class="brand" href="/" aria-label={`${site.title} home`}>
            <span
                class="brand-logo"
                set:html={logoHorizontal}
                aria-hidden="true"
            />
        </a>
        <nav class="nav-links">
            {
                nav.map((item) => (
                    <a
                        href={item.href}
                        class={isActive(item.href) ? "active" : undefined}
                    >
                        {item.label}
                    </a>
                ))
            }
        </nav>
        <div class="nav-right">
            <a
                class="icon-btn"
                href={links.github}
                aria-label="View timedart on GitHub"
                title="GitHub"
            >
                <svg
                    viewBox="0 0 16 16"
                    width="18"
                    height="18"
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path
                        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
                    ></path>
                </svg>
            </a>
            <a class="btn btn-primary nav-links" href={links.demo}>Live demo</a>
            <button
                class="icon-btn menu-btn"
                id="menuBtn"
                aria-label="Open menu"
            >
                <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                >
                    <path d="M3 6h18M3 12h18M3 18h18"></path>
                </svg>
            </button>
        </div>
    </div>
</header>

<div id="drawer">
    <div class="drawer-top">
        <span class="mono brand-mark">{site.title}</span>
        <button class="icon-btn" id="drawerClose" aria-label="Close menu">
            <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
            >
                <path d="M18 6 6 18M6 6l12 12"></path>
            </svg>
        </button>
    </div>
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    <a href={links.github}>GitHub ↗</a>
    <a href={links.demo} class="drawer-accent">Try the live demo ↗</a>
</div>

<style>
    .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(
            in srgb,
            var(--color-bg) var(--header-bg-opacity),
            transparent
        );
        backdrop-filter: blur(var(--backdrop-blur));
        -webkit-backdrop-filter: blur(var(--backdrop-blur));
        border-bottom: var(--border-width) solid var(--color-border);
    }

    .nav {
        display: flex;
        align-items: center;
        gap: var(--space-26);
        height: var(--header-height);
    }

    .brand {
        display: flex;
        align-items: center;
        gap: var(--space-10);
        height: var(--brand-height);
        color: var(
            --color-heading
        ); /* drives the logo wordmark's currentColor */
    }

    .nav-links {
        display: flex;
        gap: var(--space-26);
        margin-left: var(--space-14);
        margin-left: auto;
    }

    .nav-links a {
        color: var(--color-text);
        font-size: var(--text-base);
        font-weight: var(--font-weight-medium);
        white-space: nowrap;
    }

    .nav-links a:hover,
    .nav-links a.active {
        color: var(--color-accent-text);
    }

    .nav-right {
        display: flex;
        align-items: center;
        gap: var(--space-12);
        margin-left: auto;
    }

    .icon-btn {
        width: var(--icon-btn-size);
        height: var(--icon-btn-size);
        border-radius: var(--radius-md);
        border: var(--border-width) solid var(--color-border);
        background: var(--color-surface);
        color: var(--color-heading);
        display: grid;
        place-items: center;
        cursor: pointer;
        transition:
            border-color var(--transition-base),
            color var(--transition-base);
    }

    .icon-btn:hover {
        border-color: var(--color-border-strong);
        color: var(--color-accent-text);
    }

    .icon-btn svg {
        width: var(--icon-size);
        height: var(--icon-size);
    }

    .menu-btn {
        display: none;
    }

    .brand-mark {
        color: var(--color-accent-text);
    }

    #drawer {
        position: fixed;
        inset: 0;
        z-index: 60;
        background: var(--color-bg);
        padding: var(--space-24);
        display: none;
        flex-direction: column;
        gap: var(--space-6);
    }

    #drawer.open {
        display: flex;
    }

    .drawer-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: var(--icon-btn-size);
        margin-bottom: var(--space-20);
    }

    #drawer a {
        color: var(--color-heading);
        font-size: var(--text-xl);
        font-weight: var(--font-weight-semibold);
        padding: var(--space-14) var(--space-4);
        border-bottom: var(--border-width) solid var(--color-border);
    }

    .drawer-accent {
        color: var(--color-accent-text);
    }

    @media (max-width: 900px) {
        .nav-links {
            display: none;
        }

        .menu-btn {
            display: grid;
        }
    }
</style>

<script>
    // Re-wire on every page load — astro:page-load fires on the initial load
    // and after each view-transition navigation (the DOM is swapped, so the
    // listeners must be re-attached).
    function initDrawer() {
        const drawer = document.getElementById("drawer");
        document
            .getElementById("menuBtn")
            ?.addEventListener("click", () => drawer?.classList.add("open"));
        document
            .getElementById("drawerClose")
            ?.addEventListener("click", () => drawer?.classList.remove("open"));
        drawer
            ?.querySelectorAll("a")
            .forEach((a) =>
                a.addEventListener("click", () =>
                    drawer.classList.remove("open"),
                ),
            );
    }
    document.addEventListener("astro:page-load", initDrawer);

    // Scroll-spy: light the nav item for the homepage section in view. On the
    // docs pages there are no such sections, so it no-ops and the server-set
    // "Docs" active state stands.
    let spy: IntersectionObserver | undefined;
    function initScrollSpy() {
        spy?.disconnect();
        const byId = new Map<string, Element>();
        for (const a of document.querySelectorAll<HTMLAnchorElement>(
            '.nav-links a[href*="#"]',
        )) {
            const id = (a.getAttribute("href") || "").split("#")[1];
            if (id) byId.set(id, a);
        }
        const sections = [...byId.keys()]
            .map((id) => document.getElementById(id))
            .filter((el): el is HTMLElement => el !== null);
        if (!sections.length) return;

        let current: string | null = null;
        const setActive = (id: string) => {
            if (current === id) return;
            current = id;
            for (const [sid, a] of byId) a.classList.toggle("active", sid === id);
        };
        spy = new IntersectionObserver(
            (entries) => {
                for (const e of entries) {
                    if (e.isIntersecting) setActive(e.target.id);
                }
            },
            // A thin band ~45% down the viewport: whichever section crosses it
            // is "current".
            { rootMargin: "-45% 0px -50% 0px" },
        );
        sections.forEach((s) => spy!.observe(s));
    }
    document.addEventListener("astro:page-load", initScrollSpy);
</script>
