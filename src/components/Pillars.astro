---
import { pillars, pillarsSection } from "../config/site";

const icons: Record<string, string> = {
    grid: '<rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M3 9h18M9 4v16"></path>',
    layers: '<path d="M3 6h18M6 12h12M9 18h6"></path>',
    invoice:
        '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><path d="M14 2v6h6M9 13h6M9 17h4"></path>',
    keyboard:
        '<rect x="2" y="6" width="20" height="12" rx="2"></rect><path d="M6 10h.01M10 10h.01M14 10h.01M18 10h.01M7 14h10"></path>',
    device: '<rect x="5" y="2" width="14" height="20" rx="2"></rect><path d="M9 18h6"></path>',
};
---

<section class="pl section" id="features">
    <div class="wrap">
        <div class="section-head">
            <div class="eyebrow">{pillarsSection.eyebrow}</div>
            <h2>{pillarsSection.heading}</h2>
            <p>{pillarsSection.lede}</p>
        </div>

        <div class="pillars">
            {
                pillars.map((pillar) => (
                    <div class:list={["pillar", "surface-dark", { wide: pillar.wide }]}>
                        <div
                            class="ico"
                            set:html={`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${icons[pillar.icon]}</svg>`}
                        />
                        <h3>{pillar.title}</h3>
                        <p>{pillar.description}</p>
                        <span class="tag">{pillar.tag}</span>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .pl {
        background: var(--color-bg-2);
        border-top: var(--border-width) solid var(--color-border);
        border-bottom: var(--border-width) solid var(--color-border);
    }

    .pillars {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-18);
    }

    .pillar {
        background: var(--color-surface);
        border: var(--border-width) solid var(--color-border);
        border-radius: var(--radius-md);
        padding: var(--space-30) var(--space-28);
        transition:
            border-color var(--transition-slow),
            transform var(--transition-slow);
        position: relative;
        overflow: hidden;
    }

    .pillar:hover {
        border-color: var(--color-border-strong);
        transform: translateY(var(--translate-hover));
    }

    .pillar.wide {
        grid-column: span 2;
    }

    .pillar .ico {
        width: var(--pillar-icon-size);
        height: var(--pillar-icon-size);
        border-radius: var(--radius-md);
        display: grid;
        place-items: center;
        margin-bottom: var(--space-20);
        background: var(--color-accent-dim);
        color: var(--color-accent-text);
        border: var(--border-width) solid
            color-mix(in srgb, var(--color-accent) 30%, transparent);
    }

    .pillar .ico :global(svg) {
        width: var(--icon-size-lg);
        height: var(--icon-size-lg);
    }

    .pillar h3 {
        font-size: var(--text-xl);
        margin-bottom: var(--space-9);
    }

    .pillar p {
        color: var(--color-muted);
        font-size: var(--text-base-plus);
    }

    .pillar .tag {
        display: inline-block;
        margin-top: var(--space-14);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--color-accent-text);
        border: var(--border-width) solid var(--color-border);
        border-radius: var(--radius-md);
        padding: var(--space-2) var(--space-8);
    }

    @media (max-width: 900px) {
        .pillars {
            grid-template-columns: 1fr 1fr;
        }

        .pillar.wide {
            grid-column: span 2;
        }
    }

    @media (max-width: 640px) {
        .pillars {
            grid-template-columns: 1fr;
        }

        .pillar.wide {
            grid-column: span 1;
        }
    }
</style>
