---
import { hero, links } from "../config/site";
import Phone from "./Phone.astro";
---

<section class="hero">
    <div class="wrap">
        <div class="hero-inner">
            <div class="eyebrow">{hero.eyebrow}</div>
            <h1>
                {hero.headingPre}<span class="hl">{hero.headingHighlight}</span
                >{hero.headingPost}
            </h1>
            <p class="lede">{hero.lede}</p>
            <div class="hero-cta">
                <a class="btn btn-primary" href={links.desktopDownload}>
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        ><path
                            d="M12 15.5l-5-5 1.41-1.41L11 11.67V4h2v7.67l2.59-2.58L17 10.5l-5 5zM5 18h14v2H5z"
                        ></path></svg
                    >
                    Download
                </a>
                <a class="btn btn-ghost" href={links.demo}>
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="currentColor"><path d="M8 5v14l11-7z"></path></svg
                    >
                    Try the live demo
                </a>
                <a class="btn btn-ghost" href={links.github}>
                    <svg
                        width="17"
                        height="17"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.09.68-.22.68-.49 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.55-1.14-4.55-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.36 9.36 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.8-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.59.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2z"
                        ></path>
                    </svg>
                    View on GitHub
                </a>
            </div>
            <p class="hero-note eyebrow" set:html={hero.note} />
        </div>

        <div class="hero-shot">
            <div class="frame surface-dark desktop">
                <img src={hero.shot.src} alt={hero.shot.alt} loading="eager" />
            </div>
            {
                hero.phone && (
                    <div class="phone-wrap">
                        <Phone
                            src={hero.phone.src}
                            alt={hero.phone.alt}
                            loading="eager"
                        />
                    </div>
                )
            }
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        padding: var(--hero-padding-top) 0 var(--space-40);
        overflow: hidden;
    }

    .hero::before {
        content: "";
        position: absolute;
        inset: -20% 0 auto 0;
        height: var(--hero-glow-height);
        z-index: 0;
        background: radial-gradient(
            120% 90% at 50% -10%,
            rgba(105, 226, 40, 0.12),
            transparent 60%
        );
        pointer-events: none;
    }

    .hero .wrap {
        position: relative;
        z-index: 1;
    }

    .hero-inner {
        max-width: var(--hero-max-width);
        margin: 0 auto;
        text-align: center;
    }

    .hero h1 {
        font-size: var(--text-5xl);
        font-weight: var(--font-heading-weight);
        margin: var(--space-22) 0 0;
        letter-spacing: var(--tracking-tight);
    }

    .hero h1 .hl {
        color: var(--color-accent-text);
    }

    .hero .lede {
        font-size: var(--text-2xl);
        color: var(--color-muted);
        margin: var(--space-22) auto 0;
        max-width: var(--hero-lede-max-width);
    }

    .hero-cta {
        display: flex;
        gap: var(--space-14);
        justify-content: center;
        flex-wrap: wrap;
        margin-top: var(--space-34);
    }

    .hero-note {
        margin-top: var(--space-36);
        font-size: var(--text-sm-plus);
        color: var(--color-muted);
        font-family: var(--font-sans);
    }

    .hero-note :global(b) {
        color: var(--color-accent-text);
        font-weight: var(--font-weight-medium);
    }

    .hero-shot {
        margin: var(--space-56) auto var(--space-40);
        max-width: var(--hero-shot-max-width);
        position: relative;
        z-index: 1;
        /* Room for the phone to hang below the desktop baseline (offset, not
           flush) — matches the showcase composition. */
        padding-bottom: var(--space-40);
    }

    .hero-shot .desktop {
        width: 86%;
    }

    .hero-shot .desktop img {
        width: 100%;
        display: block;
    }

    .hero-shot .phone-wrap {
        position: absolute;
        right: 0;
        bottom: 0;
        width: clamp(160px, 18vw, 224px);
        z-index: 2;
    }

    @media (max-width: 720px) {
        /* Stack with a clear gap — no overlap — on small screens. */
        .hero-shot {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: var(--space-24);
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .hero-shot .desktop {
            width: 100%;
        }

        .hero-shot .phone-wrap {
            position: static;
            /* Fill the content column on mobile rather than a capped mockup. */
            width: 100%;
            margin-top: 0;
        }
    }

    @media (max-width: 640px) {
        .hero {
            padding: var(--hero-padding-top-sm) 0 var(--space-20);
        }
    }
</style>
