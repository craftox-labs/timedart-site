---
import { keyRows, keyboardSection } from "../config/site";
---

<section class="kb section" id="keyboard">
    <div class="wrap">
        <div class="kb-grid">
            <div>
                <div class="eyebrow">{keyboardSection.eyebrow}</div>
                <h2 class="kb-heading" set:html={keyboardSection.heading} />
                <p class="kb-lede">{keyboardSection.lede}</p>
                <div class="kb-cta">
                    <a
                        class="btn btn-primary"
                        href={keyboardSection.ctaPrimary.href}
                        >{keyboardSection.ctaPrimary.label}</a
                    >
                    <a
                        class="btn btn-soft"
                        href={keyboardSection.ctaSecondary.href}
                        >{keyboardSection.ctaSecondary.label}</a
                    >
                </div>
            </div>

            <div class="keys surface-dark">
                {
                    keyRows.map((row) => (
                        <div class="row">
                            <span class="k">
                                {row.keys.map((key) => (
                                    <kbd class:list={{ accent: key.accent }}>
                                        {key.label}
                                    </kbd>
                                ))}
                            </span>
                            <span class="act">{row.action}</span>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style>
    .kb {
        background: var(--color-bg-2);
        border-top: var(--border-width) solid var(--color-border);
        border-bottom: var(--border-width) solid var(--color-border);
    }

    .kb-grid {
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: var(--space-52);
        align-items: center;
    }

    .kb-heading {
        font-size: var(--text-4xl);
        margin: var(--space-14) 0 0;
    }

    .kb-lede {
        color: var(--color-muted);
        font-size: var(--text-lg);
        margin-top: var(--space-18);
    }

    .kb-cta {
        margin-top: var(--space-26);
        display: flex;
        gap: var(--space-12);
        flex-wrap: wrap;
    }

    .keys {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
        background: var(--color-border);
        border: var(--border-width) solid var(--color-border);
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    .keys .row {
        display: flex;
        align-items: center;
        gap: var(--space-14);
        background: var(--color-surface);
        padding: var(--space-14) var(--space-18);
    }

    .keys .row .k {
        display: flex;
        gap: var(--space-6);
        flex: 0 0 auto;
        min-width: var(--key-row-label-width);
    }

    .keys .row .act {
        color: var(--color-text);
        font-size: var(--text-base);
    }

    @media (max-width: 900px) {
        .kb-grid {
            grid-template-columns: 1fr;
            gap: var(--space-36);
        }
    }

    @media (max-width: 640px) {
        .keys .row {
            flex-wrap: wrap;
            gap: var(--space-8);
        }

        .keys .row .k {
            min-width: auto;
            width: 100%;
        }
    }
</style>
