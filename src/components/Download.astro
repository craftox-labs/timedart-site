---
import { downloadSection as d } from "../config/site";
---

<section class="section download" id="download">
    <div class="wrap">
        <div class="section-head">
            <p class="eyebrow">{d.eyebrow}</p>
            <h2>{d.heading}</h2>
            <p>{d.lede}</p>
        </div>

        <div class="dl-grid">
            {
                d.platforms.map((p) => (
                    <div class="dl-card surface-dark">
                        <h3>{p.os}</h3>
                        <div class="dl-actions">
                            {p.downloads.map((x) => (
                                <a
                                    class={`btn ${x.primary ? "btn-primary" : "btn-soft"}`}
                                    href={x.href}
                                >
                                    {x.label}
                                </a>
                            ))}
                        </div>
                        <p class="dl-note">{p.note}</p>
                    </div>
                ))
            }
        </div>

        <p class="dl-foot">
            {d.note} All builds & checksums on the <a href={d.allReleasesHref}
                >releases page</a
            >.
        </p>
    </div>
</section>

<style>
    .dl-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-20);
    }

    /* Card mirrors .pillar; surface-dark keeps it dark under the light theme. */
    .dl-card {
        background: var(--color-surface);
        border: var(--border-width) solid var(--color-border);
        border-radius: var(--radius-md);
        padding: var(--space-20) var(--space-24);
        display: flex;
        align-items: center;
        flex-direction: column;
        gap: var(--space-16);
    }

    .dl-card h3 {
        font-size: var(--text-xl);
    }

    .dl-actions {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-9);
    }

    .dl-note {
        color: var(--color-muted);
        font-size: var(--text-sm-plus);
        text-align: center;
        margin-top: auto;
    }

    .dl-foot {
        text-align: center;
        max-width: var(--narrative-max-width);
        margin: var(--space-36) auto 0;
        color: var(--color-muted);
        font-size: var(--text-sm-plus);
    }

    .dl-foot a {
        color: var(--color-accent-text);
        white-space: nowrap; /* keep "releases page" on one line */
    }

    @media (max-width: 900px) {
        .dl-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 520px) {
        .dl-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
