---
import { howItWorksSection as s, flowSteps } from "../config/site";
import clientRaw from "../assets/icons/client.svg?raw";
import projectRaw from "../assets/icons/project.svg?raw";
import taskRaw from "../assets/icons/task.svg?raw";
import timeRaw from "../assets/icons/time.svg?raw";
import invoiceRaw from "../assets/icons/invoice.svg?raw";

// The duo-tone step icons (shared with the app's onboarding). Strip the XML
// prolog so only the <svg> is inlined, and swap the two baked greens for theme
// tokens (--icon-primary / --icon-secondary) so they flip on light mode.
const themed = (svg: string) =>
    svg
        .slice(svg.indexOf("<svg"))
        .replaceAll("rgb(105,226,40)", "var(--icon-primary)")
        .replaceAll("rgb(46,108,15)", "var(--icon-secondary)");
const icons: Record<string, string> = {
    client: themed(clientRaw),
    project: themed(projectRaw),
    task: themed(taskRaw),
    time: themed(timeRaw),
    invoice: themed(invoiceRaw),
};
---

<section class="section how" id="how-it-works">
    <div class="wrap">
        <div class="section-head">
            <p class="eyebrow">{s.eyebrow}</p>
            <h2>{s.heading}</h2>
            <p>{s.lede}</p>
        </div>

        <div class="how-grid">
            <div class="frame how-shot surface-dark">
                <img src={s.shot.src} alt={s.shot.alt} loading="lazy" />
            </div>

            <ol class="flow">
                {
                    flowSteps.map((step) => (
                        <li class="flow-step">
                            <span
                                class="ico"
                                aria-hidden="true"
                                set:html={icons[step.icon]}
                            />
                            <div class="flow-body">
                                <h3>{step.label}</h3>
                                <p>{step.description}</p>
                            </div>
                        </li>
                    ))
                }
            </ol>
        </div>
    </div>
</section>

<style>
    .how {
        border-top: var(--border-width) solid var(--color-border);
    }
    .how-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: var(--space-52);
        /* Don't stretch the frame to the taller flow column — otherwise its
           chrome background shows as an empty band below the screenshot. */
        align-items: center;
    }

    .how-shot img {
        width: 100%;
    }

    /* icon flow, connected by a spine down the badges */
    .flow {
        display: flex;
        flex-direction: column;
        gap: var(--space-28);
        position: relative;
        /* Sized to roughly the item's height (label + description); the spine
           derives from this too, so they stay aligned. */
        --flow-badge-size: 45px;
    }

    .flow-step {
        display: flex;
        gap: var(--space-18);
        align-items: flex-start;
        position: relative;
    }

    /* connecting spine between badges */
    .flow-step:not(:last-child)::before {
        content: "";
        position: absolute;
        left: calc(var(--flow-badge-size) / 2 - var(--border-width));
        top: var(--flow-badge-size);
        height: calc(100% + var(--space-28) - var(--flow-badge-size));
        width: var(--border-width-thick);
        background: var(--color-border-strong);
    }

    /* Bare duo icon — no chip. Colours are baked, so it reads straight on the
       section background. */
    .flow .ico {
        flex: 0 0 auto;
        box-sizing: border-box;
        width: var(--flow-badge-size);
        height: var(--flow-badge-size);
        position: relative;
        z-index: 1;
    }

    .flow .ico :global(svg) {
        display: block;
        width: 100%;
        height: 100%;
    }

    .flow-body h3 {
        font-size: var(--text-xl);
    }

    .flow-body p {
        margin-top: var(--space-5);
        color: var(--color-muted);
        font-size: var(--text-base-plus);
    }

    @media (max-width: 900px) {
        .how-grid {
            grid-template-columns: 1fr;
            gap: var(--space-40);
        }
    }
</style>
