---
import { howItWorksSection as s, flowSteps } from "../config/site";
---

<section class="section how" id="how-it-works">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">{s.eyebrow}</p>
      <h2>{s.heading}</h2>
      <p>{s.lede}</p>
    </div>

    <div class="how-grid">
      <div class="frame how-shot surface-dark">
        <img src={s.shot.src} alt={s.shot.alt} loading="lazy" />
      </div>

      <ol class="flow">
        {
          flowSteps.map((step) => (
            <li class="flow-step">
              <span class="flow-n">{step.n}</span>
              <div class="flow-body">
                <h3>{step.label}</h3>
                <p>{step.description}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .how-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-52);
    align-items: center;
  }

  .how-shot img {
    width: 100%;
  }

  /* numbered flow, connected by a spine down the badges */
  .flow {
    display: flex;
    flex-direction: column;
    gap: var(--space-28);
    position: relative;
  }

  .flow-step {
    display: flex;
    gap: var(--space-18);
    align-items: flex-start;
    position: relative;
  }

  /* connecting spine between badges */
  .flow-step:not(:last-child)::before {
    content: "";
    position: absolute;
    left: calc(var(--flow-badge-size) / 2 - var(--border-width));
    top: var(--flow-badge-size);
    height: calc(100% + var(--space-28) - var(--flow-badge-size));
    width: var(--border-width-thick);
    background: var(--color-border-strong);
  }

  .flow-n {
    flex: 0 0 auto;
    width: var(--flow-badge-size);
    height: var(--flow-badge-size);
    border-radius: var(--radius-full);
    display: grid;
    place-items: center;
    background: var(--color-accent);
    color: var(--color-on-accent);
    font-family: var(--font-mono);
    font-weight: var(--font-weight-semibold);
    font-size: var(--text-base);
    position: relative;
    z-index: 1;
  }

  .flow-body h3 {
    font-size: var(--text-xl);
  }

  .flow-body p {
    margin-top: var(--space-5);
    color: var(--color-muted);
    font-size: var(--text-base-plus);
  }

  @media (max-width: 900px) {
    .how-grid {
      grid-template-columns: 1fr;
      gap: var(--space-40);
    }
  }
</style>
