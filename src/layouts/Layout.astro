---
import "@fontsource-variable/jetbrains-mono";
import "@fontsource-variable/raleway";
import "@fontsource-variable/raleway/wght-italic.css";
import "../styles/global.css";
import { site } from "../config/site";

interface Props {
  title?: string;
}

const { title } = Astro.props;

// Fetch the Google Analytics ID from environment variables
const gaId = import.meta.env.PUBLIC_GA_ID;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ?? site.tagline}</title>
    <meta name="description" content={site.description} />
    <meta property="og:title" content={site.title} />
    <meta property="og:description" content={site.description} />
    <meta property="og:image" content={site.ogImage} />
    <meta name="theme-color" content={site.themeColor} />
    <link rel="icon" type="image/svg+xml" href={site.favicon} />
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var stored = null;
        try {
          stored = localStorage.getItem("timedart-theme");
        } catch (e) {}
        root.setAttribute("data-theme", stored === "light" ? "light" : "dark");
      })();
    </script>

    {/* Only load analytics if the ID is present and the site is running in production */}
    {import.meta.env.PROD && gaId && (
      <>
        <!-- Global site tag (gtag.js) - Google Analytics -->
        <script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script type="text/partytown" define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', gaId);
        </script>

        <!-- View Transitions / Client Router Handler -->
        <script is:inline define:vars={{ gaId }}>
          document.addEventListener('astro:page-load', () => {
            if (window.gtag) {
              window.gtag('config', gaId, {
                page_path: window.location.pathname
              });
            }
          });
        </script>
      </>
    )}
  </head>
  <body>
    <slot />
    <script>
      // Open off-site links in a new tab. Internal "#" anchors start with
      // neither http nor a different host, so they're left alone.
      for (const a of document.querySelectorAll<HTMLAnchorElement>(
        'a[href^="http"]',
      )) {
        if (a.host !== location.host) {
          a.target = "_blank";
          a.rel = "noopener noreferrer";
        }
      }
    </script>
  </body>
</html>
